# Aether — переменные окружения
# Скопируй в .env и заполни реальными значениями
# НИКОГДА не коммить .env с реальными ключами!

# OpenAI API (обязательно — для транскрипции через Whisper)
# Получить: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=sk-...

# Anthropic Claude API (опционально — если выбран Claude как LLM провайдер)
# Получить: https://console.anthropic.com/
VITE_ANTHROPIC_API_KEY=sk-ant-...
